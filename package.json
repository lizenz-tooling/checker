{
	"name": "@lizenz/checker",
	"version": "0.0.1",
	"description": "Extract license information from installed npm packages",
	"license": "BSD-3-Clause",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"license-checker": "dist/cli.js",
		"license-checker-rseidelsohn": "dist/cli.js"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"test-watch": "vitest",
		"check": "biome check && tsc --noEmit",
		"fix": "biome check --write",
		"fix-unsafe": "biome check --write --unsafe"
	},
	"engines": {
		"node": ">=24",
		"npm": ">=11"
	},
	"engine-strict": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lizenz-tooling/checker.git"
	},
	"bugs": {
		"url": "https://github.com/lizenz-tooling/checker/issues"
	},
	"homepage": "https://github.com/lizenz-tooling/checker#readme",
	"keywords": [
		"license",
		"cli",
		"checker",
		"oss"
	],
	"dependencies": {
		"@npmcli/arborist": "9.8.0",
		"@npmcli/package-json": "8.0.0",
		"chalk": "5.6.2",
		"debug": "^4.3.4",
		"lodash.clonedeep": "^4.5.0",
		"nopt": "10.0.1",
		"semver": "7.8.5",
		"spdx-correct": "^3.2.0",
		"spdx-expression-parse": "^4.0.0",
		"spdx-satisfies": "^6.0.0",
		"treeify": "^1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@tsconfig/node24": "24.0.4",
		"@types/node": "24.13.2",
		"@types/spdx-expression-parse": "4.0.0",
		"rimraf": "6.1.3",
		"typescript": "7.0.2",
		"vite": "8.1.3",
		"vitest": "4.1.9"
	}
}
